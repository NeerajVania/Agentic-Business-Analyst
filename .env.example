# Application settings
# The name of your app environment: development, staging, production, etc.
APP_ENV=development
# Enable debug features in FastAPI / Streamlit. Set to false in production.
DEBUG=True
# Logging verbosity level.
LOG_LEVEL=INFO

# Mistral AI settings
# Your Mistral API key for LLM access. Get it from your Mistral account dashboard.
MISTRAL_API_KEY=YOUR_KEY_HERE
# Default Mistral model to use for chat and text generation.
MISTRAL_MODEL=mistral-large-latest
# Alternate smaller Mistral model for lightweight tasks.
MISTRAL_SMALL_MODEL=mistral-small-latest

# HuggingFace settings
# Optional HuggingFace API token for private embedding models or rate-limited access.
HUGGINGFACE_API_TOKEN=YOUR_KEY_HERE
# Embedding model name to use with HuggingFace.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LangSmith / LangChain tracing
# Optional LangSmith API key for tracing LangChain runs.
LANGSMITH_API_KEY=YOUR_KEY_HERE
# Enable LangChain tracing to LangSmith (True/False).
LANGCHAIN_TRACING_V2=False
# LangSmith project name for traced runs.
LANGCHAIN_PROJECT=agentic-data-analyst

# PostgreSQL database settings
# Connection string for the metadata/app database.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/agentdb
# Optional sync DB URL; defaults to a sync version of DATABASE_URL when empty.
DATABASE_SYNC_URL=

# Redis settings
# URL for the Redis instance used for conversation memory.
REDIS_URL=redis://localhost:6379/0

# ChromaDB settings
# Local path for ChromaDB storage files.
VECTORSTORE_DIR=./data/vectorstore
# Collection name used by ChromaDB.
CHROMA_COLLECTION=knowledge_base

# FastAPI backend settings
# Host where the FastAPI API is served.
API_HOST=localhost
# Port where the FastAPI API is served.
API_PORT=8000

# Authentication settings
# Secret key for signing JWT tokens and session data. Replace with a secure random value.
SECRET_KEY=YOUR_SECRET_KEY_HERE
# JWT algorithm.
ALGORITHM=HS256
# Token expiration in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Require auth for API routes (True/False).
REQUIRE_AUTH=False

# File upload paths
# Local directory for uploaded files.
UPLOAD_DIR=./data/uploads
# Local directory for generated reports.
REPORTS_DIR=./data/reports
